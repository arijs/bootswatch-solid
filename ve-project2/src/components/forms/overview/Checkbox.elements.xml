<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    form, formCheck, formCheckInput, formCheckLabel, mb3
  </family>
</contract-classes>
<component name="Checkbox">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <div class-contracts="theme mb3 formCheck">
          <input type="checkbox" class="pwhook-checkbox" class-contracts="theme formCheckInput" id="exampleCheck1" />
          <label class="pwhook-checkbox-label" class-contracts="theme formCheckLabel" for="exampleCheck1">
            Check me out
          </label>
        </div>
      </form>
    </div>
  </jsx>
</component>
