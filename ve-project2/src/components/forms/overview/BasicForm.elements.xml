<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    form, formControl, formLabel, formText, mb3
  </family>
</contract-classes>
<component name="BasicForm">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <div class-contracts="theme mb3">
          <label for="exampleInputEmail1" class-contracts="theme formLabel">
            Email address
          </label>
          <input type="email" class="pwhook-form-control" class-contracts="theme formControl" id="exampleInputEmail1" aria-describedby="emailHelp" />
          <div id="emailHelp" class-contracts="theme formText">
            We'll never share your email with anyone else.
          </div>
        </div>
        <div class-contracts="theme mb3">
          <label for="exampleInputPassword1" class-contracts="theme formLabel">
            Password
          </label>
          <input type="password" class="pwhook-form-control" class-contracts="theme formControl" id="exampleInputPassword1" />
        </div>
      </form>
    </div>
  </jsx>
</component>
