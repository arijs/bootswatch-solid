<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    form, formControl, formLabel, mb3
  </family>
</contract-classes>
<component name="FileInput">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <div class-contracts="theme mb3">
          <label class-contracts="theme formLabel" for="customFile">
            Upload
          </label>
          <input type="file" class="pwhook-file-input" class-contracts="theme formControl" id="customFile" />
        </div>
      </form>
    </div>
  </jsx>
</component>
