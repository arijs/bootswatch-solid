<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    form, formLabel, formRange, mb3
  </family>
</contract-classes>
<component name="RangeInput">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <div class-contracts="theme mb3">
          <label for="customRange3" class-contracts="theme formLabel">
            Example range
          </label>
          <input type="range" class-contracts="theme formRange" min="0" max="5" step="0.5" id="customRange3" />
        </div>
      </form>
    </div>
  </jsx>
</component>
