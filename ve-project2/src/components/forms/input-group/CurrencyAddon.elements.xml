<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    formControl, inputGroup, inputGroupText, mb3
  </family>
</contract-classes>
<component name="CurrencyAddon">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <div class-contracts="theme inputGroup mb3">
        <span class-contracts="theme inputGroupText">
          $
        </span>
        <input type="text" class-contracts="theme formControl" aria-label="Amount (to the nearest dollar)" />
        <span class-contracts="theme inputGroupText">
          .00
        </span>
      </div>
    </div>
  </jsx>
</component>
