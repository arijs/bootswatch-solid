<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    formControl, formLabel, inputGroup, inputGroupText, mb3
  </family>
</contract-classes>
<component name="UrlAddon">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <label for="basic-url" class-contracts="theme formLabel">
        Your vanity URL
      </label>
      <div class-contracts="theme inputGroup mb3">
        <span class-contracts="theme inputGroupText" id="basic-addon3">
          https://example.com/users/
        </span>
        <input type="text" class-contracts="theme formControl" id="basic-url" aria-describedby="basic-addon3" />
      </div>
    </div>
  </jsx>
</component>
