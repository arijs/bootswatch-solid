<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    form, formControl, formLabel, formRange, mb3
  </family>
</contract-classes>
<component name="DisabledFileRange">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <div class-contracts="theme mb3">
          <label class-contracts="theme formLabel" for="disabledCustomFile">
            Upload
          </label>
          <input type="file" class-contracts="theme formControl" id="disabledCustomFile" disabled="true" />
        </div>
        <div class-contracts="theme mb3">
          <label for="disabledRange" class-contracts="theme formLabel">
            Disabled range
          </label>
          <input type="range" class-contracts="theme formRange" min="0" max="5" step="0.5" id="disabledRange" disabled="true" />
        </div>
      </form>
    </div>
  </jsx>
</component>
