<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    fieldset, form, formControl, formLabel, formSelect, mb3
  </family>
</contract-classes>
<component name="DisabledFieldset">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <fieldset class-contracts="theme fieldset" disabled="true" aria-label="Disabled fieldset example">
          <div class-contracts="theme mb3">
            <label for="disabledTextInput" class-contracts="theme formLabel">
              Disabled input
            </label>
            <input type="text" id="disabledTextInput" class-contracts="theme formControl" placeholder="Disabled input" />
          </div>
          <div class-contracts="theme mb3">
            <label for="disabledSelect" class-contracts="theme formLabel">
              Disabled select menu
            </label>
            <select id="disabledSelect" class-contracts="theme formSelect">
              <option>
                Disabled select
              </option>
            </select>
          </div>
        </fieldset>
      </form>
    </div>
  </jsx>
</component>
