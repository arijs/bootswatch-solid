<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    fieldset, form, formCheck, formCheckInput, formCheckLabel, legend, legendClear, mb3
  </family>
</contract-classes>
<component name="DisabledRadioButtons">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <fieldset class-contracts="theme mb3 fieldset">
          <legend class-contracts="theme legend">
            Disabled radios buttons
          </legend>
          <div class-contracts="theme legendClear formCheck">
            <input type="radio" name="radios" class-contracts="theme formCheckInput" id="disabledRadio1" disabled="true" />
            <label class-contracts="theme formCheckLabel" for="disabledRadio1">
              Disabled radio
            </label>
          </div>
          <div class-contracts="theme mb3 formCheck">
            <input type="radio" name="radios" class-contracts="theme formCheckInput" id="disabledRadio2" disabled="true" />
            <label class-contracts="theme formCheckLabel" for="disabledRadio2">
              Another radio
            </label>
          </div>
        </fieldset>
      </form>
    </div>
  </jsx>
</component>
