<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    form, formCheck, formCheckInput, formCheckLabel, formSwitch, mb3
  </family>
</contract-classes>
<component name="DisabledSwitchCheckbox">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme form">
        <div class-contracts="theme mb3 formCheck formSwitch">
          <input class-contracts="theme formCheckInput" type="checkbox" id="disabledSwitchCheckChecked" checked="true" disabled="true" />
          <label class-contracts="theme formCheckLabel" for="disabledSwitchCheckChecked">
            Disabled checked switch checkbox input
          </label>
        </div>
      </form>
    </div>
  </jsx>
</component>
