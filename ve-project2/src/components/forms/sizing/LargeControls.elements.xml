<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    formControl, formControlLg, formSelect, formSelectLg, mb3
  </family>
</contract-classes>
<component name="LargeControls">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <div class-contracts="theme mb3">
        <input class-contracts="theme formControl formControlLg" type="text" placeholder=".form-control-lg" aria-label=".form-control-lg example" />
      </div>
      <div class-contracts="theme mb3">
        <select class-contracts="theme formSelect formSelectLg mb3" aria-label=".form-select-lg example">
          <option selected="true">
            Open this select menu
          </option>
          <option value="1">
            One
          </option>
          <option value="2">
            Two
          </option>
          <option value="3">
            Three
          </option>
        </select>
      </div>
      <div class-contracts="theme mb3">
        <input type="file" class-contracts="theme formControl formControlLg" aria-label="Large file input example" />
      </div>
    </div>
  </jsx>
</component>
