<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    colMd6, formControl, formLabel, g3, hasValidation, inputGroup, inputGroupText, invalidFeedback, isInvalid, row, rowCol
  </family>
</contract-classes>
<component name="InvalidUsernameCity">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme row g3">
        <div class-contracts="theme rowCol colMd6">
          <label for="validationServerUsername" class-contracts="theme formLabel">
            Username
          </label>
          <div class-contracts="theme inputGroup hasValidation isInvalid">
            <span class-contracts="theme inputGroupText" id="inputGroupPrepend3">
              @
            </span>
            <input type="text" class-contracts="theme formControl isInvalid" id="validationServerUsername" aria-describedby="inputGroupPrepend3" required="true" />
          </div>
          <div class-contracts="theme invalidFeedback">
            Please choose a username.
          </div>
        </div>
        <div class-contracts="theme rowCol colMd6">
          <label for="validationServer03" class-contracts="theme formLabel">
            City
          </label>
          <input type="text" class-contracts="theme formControl isInvalid" id="validationServer03" required="true" />
          <div class-contracts="theme invalidFeedback">
            Please provide a valid city.
          </div>
        </div>
      </form>
    </div>
  </jsx>
</component>
