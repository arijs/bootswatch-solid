<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="forms/contract.css">
    colMd6, formControl, formLabel, g3, isValid, row, rowCol, validFeedback
  </family>
</contract-classes>
<component name="ValidNames">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <form class-contracts="theme row g3">
        <div class-contracts="theme rowCol colMd6">
          <label for="validationServer01" class-contracts="theme formLabel">
            First name
          </label>
          <input type="text" class-contracts="theme formControl isValid" id="validationServer01" value="Mark" required="true" />
          <div class-contracts="theme validFeedback">
            Looks good!
          </div>
        </div>
        <div class-contracts="theme rowCol colMd6">
          <label for="validationServer02" class-contracts="theme formLabel">
            Last name
          </label>
          <input type="text" class-contracts="theme formControl isValid" id="validationServer02" value="Otto" required="true" />
          <div class-contracts="theme validFeedback">
            Looks good!
          </div>
        </div>
      </form>
    </div>
  </jsx>
</component>
