<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="contents/contract.css">
    markText, paragraph, smallText
  </family>
</contract-classes>
<component name="TextElements">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <p class-contracts="theme paragraph">
        You can use the mark tag to
        <mark class-contracts="theme markText">
          highlight
        </mark>
        text.
      </p>
      <p class-contracts="theme paragraph">
        <del>
          This line of text is meant to be treated as deleted text.
        </del>
      </p>
      <p class-contracts="theme paragraph">
        <s>
          This line of text is meant to be treated as no longer accurate.
        </s>
      </p>
      <p class-contracts="theme paragraph">
        <ins>
          This line of text is meant to be treated as an addition to the document.
        </ins>
      </p>
      <p class-contracts="theme paragraph">
        <u>
          This line of text will render as underlined.
        </u>
      </p>
      <p class-contracts="theme paragraph">
        <small class-contracts="theme smallText">
          This line of text is meant to be treated as fine print.
        </small>
      </p>
      <p class-contracts="theme paragraph">
        <strong>
          This line rendered as bold text.
        </strong>
      </p>
      <p class-contracts="theme paragraph">
        <em>
          This line rendered as italicized text.
        </em>
      </p>
    </div>
  </jsx>
</component>
