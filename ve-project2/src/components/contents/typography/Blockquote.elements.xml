<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="contents/contract.css">
    blockquote, blockquoteFooter, paragraph
  </family>
</contract-classes>
<component name="Blockquote">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <blockquote class-contracts="theme blockquote">
        <p class-contracts="theme paragraph">
          A well-known quote, contained in a blockquote element.
        </p>
        <footer class-contracts="theme blockquoteFooter">
          Someone famous in
          <cite title="Source Title">
            Source Title
          </cite>
        </footer>
      </blockquote>
    </div>
  </jsx>
</component>
