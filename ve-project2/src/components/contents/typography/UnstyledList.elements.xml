<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="contents/contract.css">
    listBase, listIndented, listNested, listUnstyled
  </family>
</contract-classes>
<component name="UnstyledList">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <ul class-contracts="theme listUnstyled listBase">
        <li>
          This is a list.
        </li>
        <li>
          It appears completely unstyled.
        </li>
        <li>
          Structurally, it's still a list.
        </li>
        <li>
          However, this style only applies to immediate child elements.
        </li>
        <li>
          Nested lists:
          <ul class-contracts="theme listBase listNested listIndented">
            <li>
              are unaffected by this style
            </li>
            <li>
              will still show a bullet
            </li>
            <li>
              and have appropriate left margin
            </li>
          </ul>
        </li>
        <li>
          This may still come in handy in some situations.
        </li>
      </ul>
    </div>
  </jsx>
</component>
