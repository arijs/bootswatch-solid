<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="contents/contract.css">
    table, tableBordered, tableCell, tableElement, tableHeaderCell, tableRow, tableSection, tableSm
  </family>
</contract-classes>
<component name="SmallBordered">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <table class-contracts="theme table tableElement tableSm tableBordered">
        <thead class-contracts="theme tableSection">
          <tr class-contracts="theme tableRow">
            <th class-contracts="theme tableHeaderCell">
              #
            </th>
            <th class-contracts="theme tableHeaderCell">
              First
            </th>
            <th class-contracts="theme tableHeaderCell">
              Last
            </th>
            <th class-contracts="theme tableHeaderCell">
              Handle
            </th>
          </tr>
        </thead>
        <tbody class-contracts="theme tableSection">
          <tr class-contracts="theme tableRow">
            <th class-contracts="theme tableHeaderCell">
              1
            </th>
            <td class-contracts="theme tableCell">
              Mark
            </td>
            <td class-contracts="theme tableCell">
              Otto
            </td>
            <td class-contracts="theme tableCell">
              @mdo
            </td>
          </tr>
          <tr class-contracts="theme tableRow">
            <th class-contracts="theme tableHeaderCell">
              2
            </th>
            <td class-contracts="theme tableCell">
              Jacob
            </td>
            <td class-contracts="theme tableCell">
              Thornton
            </td>
            <td class-contracts="theme tableCell">
              @fat
            </td>
          </tr>
          <tr class-contracts="theme tableRow">
            <th class-contracts="theme tableHeaderCell">
              3
            </th>
            <td class-contracts="theme tableCell" colspan="2">
              Larry the Bird
            </td>
            <td class-contracts="theme tableCell">
              @twitter
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </jsx>
</component>
