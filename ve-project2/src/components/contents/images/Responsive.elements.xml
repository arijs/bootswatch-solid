<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="contents/contract.css">
    bdPlaceholderImg, bdPlaceholderImgLg, imgFluid
  </family>
</contract-classes>
<component name="Responsive">
  <jsx>
    <div class="bd-example" class-contracts="theme bodyText containerFluid">
      <svg class-contracts="theme bdPlaceholderImg bdPlaceholderImgLg imgFluid" width="100%" height="250" xmlns="http://www.w3.org/2000/svg" aria-label="Placeholder: Responsive image" preserveAspectRatio="xMidYMid slice" tabindex="0">
        <title>
          Placeholder
        </title>
        <rect width="100%" height="100%" fill="#868e96" />
        <text x="50%" y="50%" fill="#dee2e6" dy=".3em">
          Responsive image
        </text>
      </svg>
    </div>
  </jsx>
</component>
