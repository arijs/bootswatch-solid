<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="ui/pagination/contract.css">
    pageItem, pageLink, pagination
  </family>
</contract-classes>
<component name="StandardPagination">
  <jsx>
    <div class="bd-example-ve2">
      <div class-contracts="theme containerFluid">
        <nav aria-label="Standard pagination example">
          <ul class-contracts="theme pagination">
            <li class-contracts="theme pageItem">
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme pageLink" href="#" onClick="(e) =&gt; e.preventDefault()" aria-label="Previous">
                <span aria-hidden="true">
                  &amp;laquo;
                </span>
              </a>
            </li>
            <li class-contracts="theme pageItem">
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme pageLink" href="#" onClick="(e) =&gt; e.preventDefault()">
                1
              </a>
            </li>
            <li class-contracts="theme pageItem">
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme pageLink" href="#" onClick="(e) =&gt; e.preventDefault()">
                2
              </a>
            </li>
            <li class-contracts="theme pageItem">
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme pageLink" href="#" onClick="(e) =&gt; e.preventDefault()">
                3
              </a>
            </li>
            <li class-contracts="theme pageItem">
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme pageLink" href="#" onClick="(e) =&gt; e.preventDefault()" aria-label="Next">
                <span aria-hidden="true">
                  &amp;raquo;
                </span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </jsx>
</component>
