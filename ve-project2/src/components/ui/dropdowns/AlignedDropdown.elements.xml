<contract-classes>
  <family source="ui/button-group/contract.css">
    btnGroup
  </family>
  <family source="ui/buttons/contract.css">
    btn, btnSecondary
  </family>
  <family source="ui/dropdowns/contract.css">
    btnShowHook, dropdown, dropdownDivider, dropdownHeader, dropdownItem, dropdownMenu, dropdownMenuEnd, dropdownMenuShow, dropdownToggle, dropend, dropstart, dropup
  </family>
  <family source="contents/contract.css">
    h6
  </family>
  <family source="layout/container.css">
    containerFluid
  </family>
</contract-classes>
<component name="AlignedDropdown">
  <jsx>
    <div class="bd-example-ve2" class-contracts="theme containerFluid">
      <div class-contracts="theme btnGroup">
        <div class-contracts="theme dropdown">
          <button class="pwhook-dropdown-toggle" class-contracts="theme btn btnSecondary dropdownToggle" type="button" id="dropdownRightMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
            End-aligned menu
          </button>
          <ul class="pwhook-dropdown-menu" class-contracts="theme dropdownMenu dropdownMenuEnd" aria-labelledby="dropdownRightMenuButton">
            <li>
              <h6 class-contracts="theme dropdownHeader h6">
                Dropdown header
              </h6>
            </li>
            <li>
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme dropdownItem" href="#" onClick="(e) =&gt; e.preventDefault()">
                Action
              </a>
            </li>
            <li>
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme dropdownItem" href="#" onClick="(e) =&gt; e.preventDefault()">
                Another action
              </a>
            </li>
            <li>
              <hr class-contracts="theme dropdownDivider" />
            </li>
            <li>
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme dropdownItem" href="#" onClick="(e) =&gt; e.preventDefault()">
                Separated link
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </jsx>
</component>
