<contract-classes>
  <family source="ui/alerts/contract.css">
    alertBtnClose
  </family>
  <family source="ui/buttons/contract.css">
    inputFontFamily
  </family>
  <family source="ui/toasts/contract.css">
    placeholderIcon, toast, toastBody, toastBrand, toastExample, toastFade, toastHeader, toastHide, toastRuntime, toastShow, toastShowing, toastTimestamp
  </family>
</contract-classes>
<component name="ToastExample">
  <jsx>
    <div class="bd-example" class-contracts="theme toastExample">
      <div class="pwhook-toast" class-contracts="theme toast toastRuntime" ref="toastNode" aria-live="assertive" aria-atomic="true">
        <div class-contracts="theme toastHeader">
          <svg class-contracts="theme placeholderIcon" width="20" height="20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid slice" tabindex="0">
            <rect width="100%" height="100%" fill="#007aff" />
          </svg>
          <strong class-contracts="theme toastBrand">
            Bootstrap
          </strong>
          <small class-contracts="theme toastTimestamp">
            11 mins ago
          </small>
          <button type="button" class-contracts="theme alertBtnClose inputFontFamily" data-bs-dismiss="toast" aria-label="Close">
          </button>
        </div>
        <div class-contracts="theme toastBody">
          Hello, world! This is a toast message.
        </div>
      </div>
    </div>
  </jsx>
</component>
