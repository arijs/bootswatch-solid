<contract-classes>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="ui/navs/contract.css">
    nav, navItem, navLink, navLinkActive, navLinkDisabled, navPills
  </family>
</contract-classes>
<component name="PillNav">
  <jsx>
    <div class="bd-example-ve2">
      <div class-contracts="theme containerFluid">
        <ul class-contracts="theme nav navPills">
          <li class-contracts="theme navItem">
            <!-- biome-ignore lint: <a> is used for demonstration purposes -->
            <a class-contracts="theme navLink navLinkActive" aria-current="page" href="#" onClick="(e) =&gt; e.preventDefault()">
              Active
            </a>
          </li>
          <li class-contracts="theme navItem">
            <!-- biome-ignore lint: <a> is used for demonstration purposes -->
            <a class-contracts="theme navLink" href="#" onClick="(e) =&gt; e.preventDefault()">
              Link
            </a>
          </li>
          <li class-contracts="theme navItem">
            <!-- biome-ignore lint: <a> is used for demonstration purposes -->
            <a class-contracts="theme navLink" href="#" onClick="(e) =&gt; e.preventDefault()">
              Link
            </a>
          </li>
          <li class-contracts="theme navItem">
            <!-- biome-ignore lint: <a> is used for demonstration purposes -->
            <a class-contracts="theme navLink navLinkDisabled" href="#" onClick="(e) =&gt; e.preventDefault()" tabindex="-1" aria-disabled="true">
              Disabled
            </a>
          </li>
        </ul>
      </div>
    </div>
  </jsx>
</component>
