<contract-classes>
  <family source="contents/contract.css">
    link
  </family>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="ui/alerts/contract.css">
    alert, alertBtnClose, alertDismissible, alertLink, alertPrimary
  </family>
  <family source="ui/buttons/contract.css">
    inputFontFamily
  </family>
</contract-classes>
<component name="PrimaryAlert">
  <jsx>
    <div class="bd-example-ve2" class-contracts="theme containerFluid">
      <div class-contracts="theme alert alertPrimary alertDismissible">
        A simple primary alert with
        { }
        <!-- biome-ignore lint: <a> is used for demonstration purposes -->
        <a href="#" onClick="(e) =&gt; e.preventDefault()" class-contracts="theme alertLink link">
          an example link
        </a>
        . Give it a click if you like.
        <button type="button" class-contracts="theme alertBtnClose inputFontFamily" aria-label="Close" />
      </div>
    </div>
  </jsx>
</component>
