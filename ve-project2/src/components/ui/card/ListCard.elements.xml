<contract-classes>
  <family source="contents/contract.css">
    h5, link, paragraph
  </family>
  <family source="ui/card/contract.css">
    card, cardBody, cardLink, cardText, cardTitle
  </family>
  <family source="ui/list-group/contract.css">
    listGroup, listGroupFlush, listGroupItem
  </family>
</contract-classes>
<component name="ListCard">
  <jsx>
    <div class="bd-example-ve2" class-contracts="theme">
      <div class-contracts="theme card">
        <div class-contracts="theme cardBody">
          <h5 class-contracts="theme cardTitle h5">
            Card title
          </h5>
          <p class-contracts="theme cardText paragraph">
            Some quick example text to build on the card title and make up the bulk of
            the card's content.
          </p>
        </div>
        <ul class-contracts="theme listGroup listGroupFlush">
          <li class-contracts="theme listGroupItem">
            An item
          </li>
          <li class-contracts="theme listGroupItem">
            A second item
          </li>
          <li class-contracts="theme listGroupItem">
            A third item
          </li>
        </ul>
        <div class-contracts="theme cardBody">
          <!-- biome-ignore lint: <a> is used for demonstration purposes -->
          <a href="#" onClick="(e) =&gt; e.preventDefault()" class-contracts="theme cardLink link">
            Card link
          </a>
          <!-- biome-ignore lint: <a> is used for demonstration purposes -->
          <a href="#" onClick="(e) =&gt; e.preventDefault()" class-contracts="theme cardLink link">
            Another link
          </a>
        </div>
      </div>
    </div>
  </jsx>
</component>
