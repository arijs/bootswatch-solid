<contract-classes>
  <family source="contents/contract.css">
    bdPlaceholderImg, h5, paragraph, small, mediaMiddle
  </family>
  <family source="utilities/contract.css">
    textMuted, colMd4, colMd8, g0, row
  </family>
  <family source="ui/card/contract.css">
    card, cardBody, cardText, cardTitle
  </family>
</contract-classes>
<component name="HorizontalCard">
  <jsx>
    <div class="bd-example-ve2" class-contracts="theme">
      <div class-contracts="theme card">
        <div class-contracts="theme row g0">
          <div class-contracts="theme colMd4">
            <svg class="bd-placeholder-img" class-contracts="theme bdPlaceholderImg mediaMiddle" width="100%" height="250" xmlns="http://www.w3.org/2000/svg" aria-label="Placeholder: Image" preserveAspectRatio="xMidYMid slice" tabindex="0">
              <title>
                Placeholder
              </title>
              <rect width="100%" height="100%" fill="#868e96" />
              <text x="50%" y="50%" fill="#dee2e6" dy=".3em">
                Image
              </text>
            </svg>
          </div>
          <div class-contracts="theme colMd8">
            <div class-contracts="theme cardBody">
              <h5 class-contracts="theme cardTitle h5">
                Card title
              </h5>
              <p class-contracts="theme cardText paragraph">
                This is a wider card with supporting text below as a natural lead-in
                to additional content. This content is a little bit longer.
              </p>
              <p class-contracts="theme cardText paragraph">
                <small class-contracts="theme small textMuted">
                  Last updated 3 mins ago
                </small>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </jsx>
</component>
