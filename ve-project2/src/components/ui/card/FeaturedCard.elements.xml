<contract-classes>
  <family source="contents/contract.css">
    h5, paragraph
  </family>
  <family source="utilities/contract.css">
    textMuted
  </family>
  <family source="ui/buttons/contract.css">
    btn, btnPrimary
  </family>
  <family source="ui/card/contract.css">
    card, cardBody, cardFooter, cardHeader, cardText, cardTitle
  </family>
</contract-classes>
<component name="FeaturedCard">
  <jsx>
    <div class="bd-example-ve2" class-contracts="theme">
      <div class-contracts="theme card">
        <div class-contracts="theme cardHeader">
          Featured
        </div>
        <div class-contracts="theme cardBody">
          <h5 class-contracts="theme cardTitle h5">
            Card title
          </h5>
          <p class-contracts="theme cardText paragraph">
            Some quick example text to build on the card title and make up the bulk of
            the card's content.
          </p>
          <!-- biome-ignore lint: <a> is used for demonstration purposes -->
          <a href="#" onClick="(e) =&gt; e.preventDefault()" class-contracts="theme btn btnPrimary">
            Go somewhere
          </a>
        </div>
        <div class-contracts="theme cardFooter textMuted">
          2 days ago
        </div>
      </div>
    </div>
  </jsx>
</component>
