<contract-classes>
  <family source="ui/button-group/contract.css">
    btnGroup, btnGroupButton, btnGroupInteractive, btnToolbar, marginEnd2
  </family>
  <family source="ui/buttons/contract.css">
    btn, btnSecondary
  </family>
  <family source="layout/container.css">
    containerFluid
  </family>
</contract-classes>
<component name="ButtonGroupExample">
  <jsx>
    <div class="bd-example-ve2" class-contracts="theme containerFluid">
      <div class-contracts="theme btnToolbar" role="toolbar" aria-label="Toolbar with button groups">
        <fieldset class-contracts="theme btnGroup marginEnd2" aria-label="First group">
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            1
          </button>
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            2
          </button>
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            3
          </button>
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            4
          </button>
        </fieldset>
        <fieldset class-contracts="theme btnGroup marginEnd2" aria-label="Second group">
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            5
          </button>
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            6
          </button>
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            7
          </button>
        </fieldset>
        <fieldset class-contracts="theme btnGroup" aria-label="Third group">
          <button type="button" class-contracts="theme btn btnSecondary btnGroupButton btnGroupInteractive">
            8
          </button>
        </fieldset>
      </div>
    </div>
  </jsx>
</component>
