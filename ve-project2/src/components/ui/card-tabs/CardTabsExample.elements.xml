<contract-classes>
  <family source="contents/contract.css">
    h5, paragraph
  </family>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="ui/card-tabs/contract.css">
    cardHeaderTabs
  </family>
  <family source="ui/navs/contract.css">
    nav, navItem, navLink, navLinkActive, navLinkDisabled, navTabs
  </family>
  <family source="ui/buttons/contract.css">
    btn, btnPrimary
  </family>
  <family source="ui/card/contract.css">
    card, cardBody, cardHeader, cardText, cardTitle
  </family>
</contract-classes>
<component name="CardTabsExample">
  <jsx>
    <div class="bd-example-ve2" class-contracts="theme containerFluid">
      <div class-contracts="theme card" style="{ 'text-align': 'center' }">
        <div class-contracts="theme cardHeader">
          <ul class-contracts="theme nav navTabs cardHeaderTabs">
            <li class-contracts="theme navItem">
              <button class-contracts="theme navLink navLinkActive" type="button" aria-current="true">
                Active
              </button>
            </li>
            <li class-contracts="theme navItem">
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme navLink" href="#" onClick="(e) =&gt; e.preventDefault()">
                Link
              </a>
            </li>
            <li class-contracts="theme navItem">
              <!-- biome-ignore lint: <a> is used for demonstration purposes -->
              <a class-contracts="theme navLink navLinkDisabled" aria-disabled="true" href="#" onClick="(e) =&gt; e.preventDefault()">
                Disabled
              </a>
            </li>
          </ul>
        </div>
        <div class-contracts="theme cardBody">
          <h5 class-contracts="theme cardTitle h5">
            Special title treatment
          </h5>
          <p class-contracts="theme cardText paragraph">
            With supporting text below as a natural lead-in to additional content.
          </p>
          <!-- biome-ignore lint: <a> is used for demonstration purposes -->
          <a href="#" onClick="(e) =&gt; e.preventDefault()" class-contracts="theme btn btnPrimary">
            Go somewhere
          </a>
        </div>
      </div>
    </div>
  </jsx>
</component>
