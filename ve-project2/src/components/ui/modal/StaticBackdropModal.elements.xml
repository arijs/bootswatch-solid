<contract-classes>
  <family source="contents/contract.css">
    h5
  </family>
  <family source="layout/container.css">
    containerFluid
  </family>
  <family source="theme-contract.css">
    bodyText
  </family>
  <family source="ui/alerts/contract.css">
    alertBtnClose
  </family>
  <family source="ui/buttons/contract.css">
    btn, btnPrimary, btnSecondary
  </family>
  <family source="ui/modal/contract.css">
    actionsRow, fade, flexWrap, justifyContentBetween, modal, modalBackdrop, modalBody, modalContent, modalDialog, modalFade, modalFooter, modalHeader, modalOpenHook, modalShowHook, modalTitle
  </family>
</contract-classes>
<component name="StaticBackdropModal">
  <jsx>
    <fragment>
      <div class="bd-example" class-contracts="theme containerFluid">
        <div class-contracts="theme actionsRow justifyContentBetween flexWrap">
          <button type="button" class="pwhook-modal-trigger" class-contracts="theme btn btnPrimary" data-bs-toggle="modal" data-bs-target="#staticBackdropLive">
            Launch static backdrop modal
          </button>
        </div>
      </div>
      <div class="pwhook-modal" class-contracts="theme bodyText modal modalFade fade" id="staticBackdropLive" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="staticBackdropLiveLabel" aria-hidden="true">
        <div class-contracts="theme modalDialog">
          <div class-contracts="theme modalContent">
            <div class-contracts="theme modalHeader">
              <h5 class-contracts="theme h5 modalTitle" id="staticBackdropLiveLabel">
                Modal title
              </h5>
              <button type="button" class-contracts="theme alertBtnClose" data-bs-dismiss="modal" aria-label="Close">
              </button>
            </div>
            <div class-contracts="theme modalBody">
              <p>
                I will not close if you click outside me. Don't even try to press
                escape key.
              </p>
            </div>
            <div class-contracts="theme modalFooter">
              <button type="button" class-contracts="theme btn btnSecondary" data-bs-dismiss="modal">
                Close
              </button>
              <button type="button" class-contracts="theme btn btnPrimary">
                Understood
              </button>
            </div>
          </div>
        </div>
      </div>
    </fragment>
  </jsx>
</component>
